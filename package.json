{
  "name": "clearcote-profile-manager",
  "version": "0.2.0",
  "private": true,
  "description": "Desktop manager for Clearcote browser profiles — create, save, organize, and launch coherent, persistent browser identities.",
  "license": "BSD-3-Clause",
  "author": "clearcotelabs",
  "repository": {
    "type": "git",
    "url": "https://github.com/clearcotelabs/clearcote-profile-manager.git"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "next:dev": "next dev",
    "electron:build": "tsc -p electron",
    "electron:dev": "wait-on tcp:127.0.0.1:3000 && npm run electron:build && cross-env ELECTRON_DEV=1 electron .",
    "dev": "concurrently -k -n NEXT,ELECTRON -c cyan,magenta \"npm:next:dev\" \"npm:electron:dev\"",
    "make-icon": "node scripts/make-icon.mjs",
    "build": "next build && npm run electron:build",
    "start": "cross-env ELECTRON_DEV=0 electron .",
    "dist": "npm run build && electron-builder --publish never",
    "lint": "next lint",
    "typecheck": "tsc --noEmit && tsc -p electron --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "next": "^15.1.0",
    "png-to-ico": "^2.1.8",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.clearcotelabs.profilemanager",
    "productName": "Clearcote Profile Manager",
    "files": [
      "dist-electron/**/*",
      "out/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "artifactName": "Clearcote-Profile-Manager-${version}-${arch}.${ext}",
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Clearcote-Profile-Manager-${version}-setup.${ext}"
    }
  }
}
